@@ -5,7 +5,37 @@ import jax.random
 import pytest
 
 from levanter.data import BlockShufflingDataset, PermutationDataset
-from levanter.data.dataset import ListAsyncDataset
+from levanter.data.dataset import EpochReshufflingDataset, ListAsyncDataset
+
+
+@pytest.mark.asyncio
+async def test_epoch_reshuffling_dataset_reshuffles_each_epoch():
+    n = 16
+    data = list(range(n))
+    base = ListAsyncDataset(data)
+    ds = EpochReshufflingDataset(base, jax.random.PRNGKey(0))
+
+    assert not ds.is_finite()
+    # Pull three consecutive epochs from the infinite stream.
+    epochs = [await ds.get_batch(list(range(e * n, (e + 1) * n))) for e in range(3)]
+
+    # Each epoch is a full permutation of the base (every element exactly once).
+    for ep in epochs:
+        assert sorted(ep) == data
+    # Epochs use *different* permutations (per-epoch reshuffle, not a recycled single order).
+    assert epochs[0] != epochs[1]
+    assert epochs[1] != epochs[2]
+    assert epochs[0] != epochs[2]
+
+
+@pytest.mark.asyncio
+async def test_epoch_reshuffling_dataset_is_deterministic():
+    data = list(range(16))
+    ds1 = EpochReshufflingDataset(ListAsyncDataset(list(data)), jax.random.PRNGKey(0))
+    ds2 = EpochReshufflingDataset(ListAsyncDataset(list(data)), jax.random.PRNGKey(0))
+    b1 = await ds1.get_batch(list(range(40)))
+    b2 = await ds2.get_batch(list(range(40)))
+    assert b1 == b2
 
 
