+class EpochReshufflingDataset(AsyncDataset[T_co]):
+    """Infinite dataset that reshuffles the base dataset independently on every epoch.
+
+    For a global index ``i`` over a base of length ``N``: ``epoch = i // N``, ``pos = i % N``, and the
+    item is ``base[Permutation(N, fold_in(key, epoch))(pos)]`` — i.e. each pass over the data uses a
+    fresh permutation seeded by the epoch number. This is the per-epoch reshuffling that a single
+    [PermutationDataset][] (recycled by [MixtureDataset][]'s modulo) does *not* provide, and it
+    matches PyTorch's ``DataLoader(shuffle=True)`` behaviour.
+
+    The dataset is infinite, so when used as a mixture component its indices are passed through
+    un-wrapped (``MixtureDataset`` only applies modulo recycling to *finite* components).
+    """
+
+    def __init__(self, dataset: AsyncDataset[T_co], key: PRNGKeyArray, perm_type: PermType = "feistel"):
+        super().__init__()
+        self.dataset = dataset
+        self.key = _key_on_local_cpu(key)
+        self._perm_type = perm_type
+        self._perms: dict[int, Permutation] = {}
+
+    def is_finite(self) -> bool:
+        return False
+
+    async def async_len(self) -> int:
+        raise ValueError("EpochReshufflingDataset is infinite; async_len is undefined.")
+
+    async def final_length_is_known(self) -> bool:
+        return False
+
+    async def current_len(self) -> Optional[int]:
+        return None
+
+    async def wait_until_len_at_least(self, length: int) -> int:
+        # Infinite: any requested position is reachable once the base has at least one full epoch.
+        await self.dataset.wait_until_len_at_least(await self.dataset.async_len())
+        return length
+
+    async def _perm_for_epoch(self, epoch: int) -> Permutation:
+        if epoch not in self._perms:
+            n = await self.dataset.async_len()
+            self._perms[epoch] = Permutation.make(self._perm_type, n, _fold_in_on_local_cpu(self.key, epoch))
+        return self._perms[epoch]
+
+    async def _map_index(self, index: int) -> int:
+        n = await self.dataset.async_len()
+        epoch, pos = divmod(int(index), n)
+        perm = await self._perm_for_epoch(epoch)
+        return int(perm(pos))
+
+    async def getitem_async(self, index: int) -> T_co:
+        return await self.dataset.getitem_async(await self._map_index(index))
+
+    async def get_batch(self, indices: Sequence[int]) -> Sequence[T_co]:
+        mapped = [await self._map_index(i) for i in indices]
+        return await self.dataset.get_batch(mapped)
+
+
